# Hermes profile env example
# Copy to ~/.hermes/profiles/<profile>/.env

TELEGRAM_BOT_TOKEN=
[REDACTED]
TELEGRAM_HOME_CHANNEL=<your-telegram-user-id>
TELEGRAM_HOME_CHANNEL_NAME=<your-name>

HERMES_PROFILE=<profile-name>
HERMES_AGENT_NAME=<Agent Display Name>

# Optional shared providers; can also live in root ~/.hermes/.env
OPENROUTER_API_KEY=
[REDACTED]
ANTHROPIC_API_KEY=
[REDACTED]
